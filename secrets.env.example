# secrets.env.example — copy to security/secrets.env and fill in real values.
# This file is safe to commit; secrets.env is gitignored.

# ---------------------------------------------------------------------------
# nuix-mcp
# ---------------------------------------------------------------------------
NUIX_AUTOMATE_BASE_URL=https://nuix.example.com
NUIX_AUTOMATE_API_TOKEN=

# Required Nuix resource IDs (GUIDs from the Automate admin UI)
NUIX_AUTOMATE_LIBRARY_ID=
NUIX_AUTOMATE_REPOSITORY_ID=
NUIX_AUTOMATE_REPOSITORY_NAME=
NUIX_AUTOMATE_RESOURCE_POOL_ID=
NUIX_AUTOMATE_MATTER_ID=
NUIX_AUTOMATE_EXECUTION_PROFILE_ID=
NUIX_AUTOMATE_SESSION_WORKFLOW_ID=
NUIX_AUTOMATE_SEARCH_WORKFLOW_ID=
NUIX_AUTOMATE_UPLOAD_FILE_LIBRARY_ID=
NUIX_AUTOMATE_UPLOAD_FILE_LIBRARY_NAME=

# Path where Nuix case files are stored
NUIX_AUTOMATE_CASES_BASE_PATH=/cases

# Optional tuning (sensible defaults if omitted)
NUIX_AUTOMATE_VERIFY_SSL=true
NUIX_AUTOMATE_TRUST_ENV=false
NUIX_AUTOMATE_HTTP_TIMEOUT=30
NUIX_AUTOMATE_WORKFLOW_TIMEOUT=600
NUIX_AUTOMATE_SEARCH_TIMEOUT=300
NUIX_AUTOMATE_VALIDATION_TIMEOUT=60
NUIX_AUTOMATE_RETRY_ATTEMPTS=3
NUIX_AUTOMATE_RETRY_INITIAL_DELAY=2
NUIX_AUTOMATE_RETRY_MAX_DELAY=10
NUIX_AUTOMATE_RETRY_BACKOFF_FACTOR=2
NUIX_AUTOMATE_AUDIT_LOG=false
NUIX_AUTOMATE_SKIP_FOLDERS=
NUIX_JOB_START_TIMEOUT=120
NUIX_SESSION_START_TIMEOUT=120
NUIX_SESSION_IDLE_TIMEOUT=1800
NUIX_SESSION_POLL_INTERVAL=5

# ---------------------------------------------------------------------------
# memgraph-mcp
# ---------------------------------------------------------------------------
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_BOLT_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASS=
MEMGRAPH_DATABASE=memgraph
MEMGRAPH_ENCRYPTED=false
MEMGRAPH_TLS_TRUST=false
MEMGRAPH_TLS_CA_FILE=
MEMGRAPH_RETRY_ATTEMPTS=3
MEMGRAPH_RETRY_INITIAL_DELAY=1
MEMGRAPH_RETRY_MAX_DELAY=10
MEMGRAPH_RETRY_BACKOFF_FACTOR=2

# ---------------------------------------------------------------------------
# graphaware-mcp
# ---------------------------------------------------------------------------
HUME_URL=http://localhost:8080
HUME_WEB_URL=http://localhost:8081
HUME_USER=
HUME_PASSWORD=
GRAPHAWARE_COMPOSE_FILE=/path/to/docker-compose.yml

# ---------------------------------------------------------------------------
# deployment-ops-mcp
# ---------------------------------------------------------------------------
AUTOINSTALL_PASSWORD=

# Path to the cases directory (shared across MCPs)
CASE_ROOT=/cases
