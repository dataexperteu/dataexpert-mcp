# ──────────────────────────────────────────────────────────────────────────
# Zoho MCP server — environment template
# Copy to .env (local), or provide these keys via the shared secrets.env / the
# container's env. No database — the server is fully self-contained.
# ──────────────────────────────────────────────────────────────────────────

# --- MCP server ---
# Port the Streamable HTTP endpoint listens on (inside the container).
MCP_PORT=3001

# --- Zoho OAuth (EU datacenter) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Datacenter region. Only 'eu' is tested/approved. Drives the API + accounts base URLs.
ZOHO_DC=eu
# The Zoho login email that owns the token (informational).
ZOHO_USER_MAIL=
# Optional — only needed if a redirect_uri was set when generating the grant token.
ZOHO_REDIRECT_URI=

# The long-lived Zoho refresh token. Obtain ONCE via `npm run bootstrap` (it prints
# it). Stable across refreshes, so it lives here like any other static credential.
ZOHO_REFRESH_TOKEN=

# --- Bootstrap only (set in shell, NEVER commit) ---
# A 10-minute grant token from api-console.zoho.eu, consumed once by `npm run bootstrap`.
# ZOHO_BOOTSTRAP_GRANT_TOKEN=1000.xxxxxxxx...
