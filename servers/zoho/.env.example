# ──────────────────────────────────────────────────────────────────────────
# Zoho MCP server — environment template
# Copy to .env (local) or provide via the container's env_file (.env.zoho-mcp).
# This file is the AUTHORITATIVE template now that the MCP owns Zoho secrets.
# ──────────────────────────────────────────────────────────────────────────

# --- MCP server ---
# Port the Streamable HTTP endpoint listens on (inside the container).
MCP_PORT=3001

# --- Datastore (the MCP's OWN Postgres, not the CSM database) ---
# Points at the zoho-mcp-db service on the internal docker network.
DATABASE_URL=postgresql://zoho_mcp:CHANGE_ME@zoho-mcp-db:5432/zoho_mcp

# --- Zoho OAuth (EU datacenter) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# The Zoho login email that owns the tokens — used as the token-store key.
ZOHO_USER_MAIL=
# Datacenter region. Only 'eu' is tested/approved. Drives the API + accounts base URLs.
ZOHO_DC=eu
# Optional — only needed if a redirect_uri was set when generating the grant token.
ZOHO_REDIRECT_URI=

# --- Token encryption (MUST match the value the existing token row was written with) ---
# At cutover this is MOVED (not regenerated) from the CSM app's env so the existing
# enc:v1: refresh token decrypts as-is and we avoid a re-bootstrap. Generate a fresh
# one only for a brand-new install:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ZOHO_TOKEN_ENCRYPTION_KEY=

# --- Bootstrap only (set in shell, NEVER commit / NEVER put in a persisted .env) ---
# A 10-minute grant token from api-console.zoho.eu, consumed once by `npm run bootstrap`.
# ZOHO_BOOTSTRAP_GRANT_TOKEN=1000.xxxxxxxx...
